( Test thread-local storage with memory banking via dev[0xda] )

|10 @Console &vector $2 &read $1 &pad $4 &type $1 &write $1 &error $1

|d0 @Threads
    &cmd      $1
    &errno    $1
    &a0       $2
    &a1       $2
    &a2       $2
    &r0       $2
    &uselocalstorage    $1

  
|0100 

@on-reset ( -> )
  ( Write unique values to global memory at 0x0200-0x0202 )
  #aa ;test-addr STA
  #bb ;test-addr INC2 STA
  #cc ;test-addr INC2 INC2 STA
  
  ( Create first thread - will use local storage )
  ;worker1 .Threads/a0 DEO2
  #0000 .Threads/a1 DEO2
  #0000 .Threads/a2 DEO2
  #01 .Threads/cmd DEO
  .Threads/r0 DEI2 ;thread1 STA2
  
  ( Create second thread - will use local storage )
  ;worker2 .Threads/a0 DEO2
  #0000 .Threads/a1 DEO2
  #0000 .Threads/a2 DEO2
  #01 .Threads/cmd DEO
  .Threads/r0 DEI2 ;thread2 STA2
  
  ( Join first thread )
  ;thread1 LDA2 .Threads/a0 DEO2
  #02 .Threads/cmd DEO
  
  ( Join second thread )
  ;thread2 LDA2 .Threads/a0 DEO2
  #02 .Threads/cmd DEO
  
  ( Print global memory values - should be unchanged )
  ;test-addr LDA ;phex JSR2
  #0a .Console/error DEO
  
  ;test-addr INC2 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ;test-addr INC2 INC2 LDA ;phex JSR2
  #0a .Console/error DEO

  ( what did we read before writing to local storage? these should be zero )
  ;read1 LDA ;phex JSR2
  #0a .Console/error DEO
  ;read1 INC2 LDA ;phex JSR2
  #0a .Console/error DEO
  ;read1 INC2 INC2 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ( Print thread1 results from result area )
  ;result1 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ;result1 INC2 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ;result1 INC2 INC2 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ( Print thread2 results from result area )
  ;result2 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ;result2 INC2 LDA ;phex JSR2
  #0a .Console/error DEO
  
  ;result2 INC2 INC2 LDA ;phex JSR2
  #0a .Console/error DEO

  ( what did we read before writing to local storage? )
  
BRK

@worker1 ( -> )
  ( Set local storage index to current thread number )
  #ff .Threads/uselocalstorage DEO

  ( these reads should now be zero if local storage is working )
  ;test-addr LDA
  ;test-addr INC2 LDA
  ;test-addr INC2 INC2 LDA

  #00 .Threads/uselocalstorage DEO
  ;read1 INC2 INC2 STA
  ;read1 INC2 STA
  ;read1 STA

  ( Switch to local storage for this thread )
  #ff .Threads/uselocalstorage DEO
  
  ( Write thread-specific values to local version of memory )
  #11 ;test-addr STA
  #22 ;test-addr INC2 STA
  #33 ;test-addr INC2 INC2 STA

  ( Read back from local storage to stack )
  ;test-addr LDA
  ;test-addr INC2 LDA
  ;test-addr INC2 INC2 LDA
  
  ( Switch to global memory )
  #00 .Threads/uselocalstorage DEO

  
  ( Store from stack to result1 area in global memory )
  ;result1 INC2 INC2 STA
  ;result1 INC2 STA
  ;result1 STA
  BRK

@worker2 ( -> )
  ( Set local storage index to current thread number )
  #ff .Threads/uselocalstorage DEO
  
  ( Write thread-specific values to local 0x0200-0x0202 )
  #44 ;test-addr STA
  #55 ;test-addr INC2 STA
  #66 ;test-addr INC2 INC2 STA

  ( Read back from local storage to stack )
  ;test-addr LDA
  ;test-addr INC2 LDA
  ;test-addr INC2 INC2 LDA
  
  ( Switch to global memory )
  #00 .Threads/uselocalstorage DEO
  
  ( Store from stack to result2 area in global memory )
  ;result2 INC2 INC2 STA
  ;result2 INC2 STA
  ;result2 STA
  BRK

@phex ( byte -- )
    DUP #04 SFT ,&char JSR
    &char ( char -- ) 
        #0f AND DUP #09 GTH #27 MUL ADD [ LIT "0 ] ADD .Console/error DEO
JMP2r

@test-addr $3
@result1 $3
@result2 $3
@read1  $3
@read2  $3
@thread1 $2
@thread2 $2
