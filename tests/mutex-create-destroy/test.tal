( Test mutex create and destroy )

|10 @Console &vector $2 &read $1 &pad $4 &type $1 &write $1 &error $1

|d0 @Threads
  &cmd      $1
  &errno    $1
  &a0       $2
  &a1       $2
  &a2       $2
  &r0       $2
  &uselocalstorage    $1

|0100

@on-reset ( -> )
  
  #04 
  .Threads/cmd DEO      ( Create a mutex )
  
  
  .Threads/errno DEI        ( Check status should be 0 for success )
  ;pdec JSR2  ( write result to console )
  #0a 
  .Console/write DEO ( newline )
  
  .Threads/r0 DEI2
  
  .Threads/a0 DEO2
  #05
  .Threads/cmd DEO
  
  .Threads/errno DEI
  ;pdec JSR2  ( write result to console )
  #0a
BRK


@pdec ( short* -- )
    #000a SWP2 [ LITr ff ]
    &>get ( -- )
        SWP2k DIV2k MUL2 SUB2 STH
        POP OVR2 DIV2 ORAk ?&>get
    POP2 POP2
    &>put ( -- )
        STHr INCk ?{ POP JMP2r }
        [ LIT "0 ] ADD .Console/error DEO !&>put
