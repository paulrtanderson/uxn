( Test mutex with threads protecting shared counter )

|10 @Console &vector $2 &read $1 &pad $4 &type $1 &write $1 &error $1

|d0 @Threads
  &cmd      $1
  &errno    $1
  &a0       $2
  &a1       $2
  &a2       $2
  &r0       $2
  &uselocalstorage    $1

  
|0100 

@on-reset ( -> )
  ( Create mutex )
  #04 .Threads/cmd DEO
  .Threads/r0 DEI2 ;mutex STA2
  
  ( Initialize counter to 0 )
  #0000 ;counter STA2
  
  ( Create first thread )
  ;worker .Threads/a0 DEO2
  #0000 .Threads/a1 DEO2
  #0000 .Threads/a2 DEO2
  #01 .Threads/cmd DEO
  .Threads/r0 DEI2 ;thread1 STA2
  
  ( Create second thread )
  ;worker .Threads/a0 DEO2
  #0000 .Threads/a1 DEO2
  #0000 .Threads/a2 DEO2
  #01 .Threads/cmd DEO
  .Threads/r0 DEI2 ;thread2 STA2
  
  ( Join first thread )
  ;thread1 LDA2 .Threads/a0 DEO2
  #02 .Threads/cmd DEO
  
  ( Join second thread )
  ;thread2 LDA2 .Threads/a0 DEO2
  #02 .Threads/cmd DEO
  
  ( Print final counter value - should be 20000 )
  ;counter LDA2 ;pdec JSR2  ( write result to console )
  
  ( Destroy mutex ) 
  ;mutex LDA2 .Threads/a0 DEO2
  #05 .Threads/cmd DEO
BRK

@worker ( -> )
  #2710 ( loop 10000 times )
  &loop
    ( Lock mutex )
    ;mutex LDA2 .Threads/a0 DEO2
    #06 .Threads/cmd DEO
    
    ( Increment counter )
    ;counter LDA2   ( load counter short )
    INC2            ( increment counter )
    ;counter STA2   ( store back updated counter short )
    
    ( Unlock mutex )
    ;mutex LDA2 .Threads/a0 DEO2
    #07 .Threads/cmd DEO
    
    #0001 SUB2 
    
    DUP2 #0000 NEQ2 ?&loop
    POP2
  BRK

@pdec ( short* -- )
    #000a SWP2 [ LITr ff ]
    &>get ( -- )
        SWP2k DIV2k MUL2 SUB2 STH
        POP OVR2 DIV2 ORAk ?&>get
    POP2 POP2
    &>put ( -- )
        STHr INCk ?{ POP JMP2r }
        [ LIT "0 ] ADD .Console/error DEO !&>put

@counter $2
@mutex $2
@thread1 $2
@thread2 $2